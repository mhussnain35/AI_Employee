# Environment Variables Template for AI Employee
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git - it's already in .gitignore

# ===========================================
# Gmail API Configuration (Silver Tier)
# ===========================================
# Get these from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REDIRECT_URI=http://localhost:8080
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly

# ===========================================
# WhatsApp Configuration (Silver Tier)
# ===========================================
# WhatsApp Web uses session-based auth (no API key needed)
# Session data is stored in sessions/whatsapp/ folder
# Keywords to monitor for urgent messages
WHATSAPP_KEYWORDS=urgent,asap,invoice,payment,help
WHATSAPP_CHECK_INTERVAL=30

# ===========================================
# Odoo ERP Configuration (Gold Tier)
# ===========================================
# ODOO_API_KEY=your-odoo-api-key
# ODOO_DATABASE=mydb
# ODOO_URL=https://my-odoo-instance.com

# ===========================================
# Meta/Facebook Configuration (Gold Tier)
# ===========================================
# META_APP_ID=your-app-id
# META_APP_SECRET=your-app-secret
# META_ACCESS_TOKEN=your-access-token

# ===========================================
# Twitter/X Configuration (Gold Tier)
# ===========================================
# TWITTER_API_KEY=your-api-key
# TWITTER_API_SECRET=your-api-secret
# TWITTER_BEARER_TOKEN=your-bearer-token

# ===========================================
# LinkedIn Configuration (Gold Tier)
# ===========================================
# LINKEDIN_CLIENT_ID=your-client-id
# LINKEDIN_CLIENT_SECRET=your-client-secret
# LINKEDIN_ACCESS_TOKEN=your-access-token
