# Environment Variables Template for AI Employee
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git - it's already in .gitignore

# ===========================================
# AI Brain Configuration
# ===========================================
# Uses Claude Code CLI directly - NO API KEY NEEDED!
# Install from: https://claude.com/claude-code
# Authenticate with: claude login
AI_BRAIN=claude  # Options: claude (uses Claude Code CLI)

# ===========================================
# Claude Code CLI Configuration
# ===========================================
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096
CLAUDE_TIMEOUT=300

# ===========================================
# Gmail API Configuration
# ===========================================
# Get from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REDIRECT_URI=http://localhost
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly

# ===========================================
# WhatsApp Configuration
# ===========================================
# WhatsApp Web uses session-based auth (no API key needed)
WHATSAPP_KEYWORDS=urgent,asap,invoice,payment,help
WHATSAPP_CHECK_INTERVAL=30
